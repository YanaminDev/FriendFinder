{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {

    "module": "commonjs",
    "target": "es2018",
    "lib" : ["es2018"],
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck" : true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
