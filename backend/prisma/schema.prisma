generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id                String              @id @default(uuid())
  user_show_name         String              @db.VarChar(50)
  username               String              @unique
  password               String
  sex                    Sex
  age                    Int
  interested_gender      Sex
  birth_of_date          DateTime
  role                   Role                @default(user)
  isOnline               Boolean             @default(false)
  isBanned               Boolean             @default(false)
  CancellationAsReviewee Cancellation[]      @relation("RevieweeCancellation")
  CancellationAsReviewer Cancellation[]      @relation("ReviewerCancellation")
  chat1                  Chat[]              @relation("User1Chat")
  chat2                  Chat[]              @relation("User2Chat")
  chat_message           Chat_Message[]
  experiencesAsReviewee  Experience[]        @relation("RevieweeExperience")
  experiencesAsReviewer  Experience[]        @relation("ReviewerExperience")
  find_match             Find_Match?
  locationProposals      Location_Proposal[] @relation("ProposerProposal")
  location_review        Location_review[]
  matchesAsUser1         Match[]             @relation("User1Match")
  matchesAsUser2         Match[]             @relation("User2Match")
  receivedNotifications  Notification[]      @relation("ReceiverNotification")
  sentNotifications      Notification[]      @relation("SenderNotification")
  info                   User_Information?
  life_style             User_Life_Style?
  user_review_received   User_Review[]       @relation("ReviewedUserReview")
  user_review_given      User_Review[]       @relation("ReviewerReview")
  images                 User_image[]

  @@index([username, password, user_show_name, interested_gender])
}

model User_image {
  id        String   @id @default(uuid())
  user_id   String
  imageUrl  String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [user_id], references: [user_id])

  @@index([user_id, imageUrl])
}

model User_Information {
  user_id      String       @id
  user_height  Int
  user_bio     String?
  blood_group  Blood_Group?
  language_id  String?
  education_id String?
  education    Education?   @relation(fields: [education_id], references: [id])
  language     Language?    @relation(fields: [language_id], references: [id])
  user         User         @relation(fields: [user_id], references: [user_id])

  @@index([user_id, user_bio])
}

model Language {
  id    String             @id @default(uuid())
  name  String             @unique @db.VarChar(50)
  icon  String             @db.VarChar(50)
  users User_Information[]

  @@index([name])
}

model Education {
  id    String             @id @default(uuid())
  name  String             @unique @db.VarChar(50)
  icon  String             @db.VarChar(50)
  users User_Information[]

  @@index([name])
}

model User_Life_Style {
  user_id        String      @id
  looking_for_id String
  drinking_id    String
  pet_id         String
  smoke_id       String
  workout_id     String
  drinking       Drinking    @relation(fields: [drinking_id], references: [id])
  looking_for    Looking_for @relation(fields: [looking_for_id], references: [id])
  pet            Pet         @relation(fields: [pet_id], references: [id])
  smoke          Smoke       @relation(fields: [smoke_id], references: [id])
  user           User        @relation(fields: [user_id], references: [user_id])
  workout        Workout     @relation(fields: [workout_id], references: [id])

  @@index([looking_for_id])
}

model Looking_for {
  id              String            @id @default(uuid())
  name            String            @unique @db.VarChar(50)
  icon            String            @db.VarChar(50)
  user_life_style User_Life_Style[]

  @@index([name])
}

model Drinking {
  id              String            @id @default(uuid())
  name            String            @unique @db.VarChar(50)
  icon            String            @db.VarChar(50)
  user_life_style User_Life_Style[]

  @@index([name])
}

model Pet {
  id              String            @id @default(uuid())
  name            String            @unique @db.VarChar(50)
  icon            String            @db.VarChar(50)
  user_life_style User_Life_Style[]

  @@index([name])
}

model Smoke {
  id              String            @id @default(uuid())
  name            String            @unique @db.VarChar(50)
  icon            String            @db.VarChar(50)
  user_life_style User_Life_Style[]

  @@index([name])
}

model Workout {
  id              String            @id @default(uuid())
  name            String            @unique @db.VarChar(50)
  icon            String            @db.VarChar(50)
  user_life_style User_Life_Style[]

  @@index([name])
}

model Location {
  id              String              @id @default(uuid())
  name            String              @db.VarChar(50)
  description     String?
  phone           String?
  position_id     String
  activity_id     String
  open_date       String?
  open_time       String?
  close_time      String?
  activity        Activity            @relation(fields: [activity_id], references: [id])
  position        Position            @relation(fields: [position_id], references: [id])
  proposals       Location_Proposal[]
  location_image  Location_image[]
  location_review Location_review[]
  match           Match[]

  @@index([name, position_id, activity_id, open_date, open_time])
}

model Location_image {
  id          String   @id @default(uuid())
  location_id String
  imageUrl    String   @unique
  createdAt   DateTime @default(now())
  location    Location @relation(fields: [location_id], references: [id])

  @@index([location_id, imageUrl])
}

model Location_review {
  id          String   @id @default(uuid())
  location_id String
  user_id     String
  status      Int
  createdAt   DateTime @default(now())
  match_id    String
  review_text String?  @default("")
  location    Location @relation(fields: [location_id], references: [id])
  match       Match    @relation(fields: [match_id], references: [id])
  user        User     @relation(fields: [user_id], references: [user_id])

  @@index([location_id, user_id, match_id, status])
}

model User_Review {
  id               String   @id @default(uuid())
  user_id          String
  reviewed_user_id String
  status           Int
  createdAt        DateTime @default(now())
  match_id         String
  review_text      String?  @default("")
  match            Match    @relation(fields: [match_id], references: [id])
  reviewed_user    User     @relation("ReviewedUserReview", fields: [reviewed_user_id], references: [user_id])
  user             User     @relation("ReviewerReview", fields: [user_id], references: [user_id])

  @@index([user_id, reviewed_user_id, match_id, status])
}

model Activity {
  id          String       @id @default(uuid())
  name        String       @unique @db.VarChar(50)
  icon        String       @db.VarChar(50)
  find_match1 Find_Match[] @relation("activity1")
  find_match2 Find_Match[] @relation("activity2")
  find_match3 Find_Match[] @relation("activity3")
  location    Location[]
  match       Match[]

  @@index([name])
}

model Match {
  id                 String              @id @default(uuid())
  user1_id           String
  user2_id           String
  location_id        String?
  activity_id        String
  cancel_status      Boolean             @default(false)
  end_date           DateTime?
  createdAt          DateTime            @default(now())
  position_id        String
  cancellation       Cancellation[]
  experience         Experience[]
  location_proposals Location_Proposal[]
  location_review    Location_review[]
  activity           Activity            @relation(fields: [activity_id], references: [id])
  location           Location?           @relation(fields: [location_id], references: [id])
  position           Position            @relation(fields: [position_id], references: [id])
  user1              User                @relation("User1Match", fields: [user1_id], references: [user_id])
  user2              User                @relation("User2Match", fields: [user2_id], references: [user_id])
  user_review        User_Review[]

  @@index([user1_id, user2_id, location_id, activity_id, position_id])
}

model Location_Proposal {
  id          String                   @id @default(uuid())
  match_id    String
  proposer_id String
  location_id String
  status      Location_Proposal_Status @default(pending)
  createdAt   DateTime                 @default(now())
  location    Location                 @relation(fields: [location_id], references: [id])
  match       Match                    @relation(fields: [match_id], references: [id])
  proposer    User                     @relation("ProposerProposal", fields: [proposer_id], references: [user_id])

  @@index([match_id, status])
}

model Find_Match {
  user_id      String    @id
  position_id  String
  activity_id1 String?
  activity_id2 String?
  activity_id3 String?
  activity1    Activity? @relation("activity1", fields: [activity_id1], references: [id])
  activity2    Activity? @relation("activity2", fields: [activity_id2], references: [id])
  activity3    Activity? @relation("activity3", fields: [activity_id3], references: [id])
  position     Position  @relation(fields: [position_id], references: [id])
  user         User      @relation(fields: [user_id], references: [user_id])

  @@index([position_id])
}

model Chat {
  id          String         @id @default(uuid())
  user1_id    String
  user2_id    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user1       User           @relation("User1Chat", fields: [user1_id], references: [user_id])
  user2       User           @relation("User2Chat", fields: [user2_id], references: [user_id])
  chatMessage Chat_Message[]

  @@unique([user1_id, user2_id])
  @@index([user1_id, user2_id])
  @@index([updatedAt])
}

model Chat_Message {
  id        String   @id @default(uuid())
  chat_id   String
  message   String
  sender_id String
  createdAt DateTime @default(now())
  chatType  String   @default("text")
  isRead    Boolean  @default(false)
  status    String   @default("sent")
  chat      Chat     @relation(fields: [chat_id], references: [id])
  sender    User     @relation(fields: [sender_id], references: [user_id])

  @@index([chat_id, sender_id, message])
  @@index([chat_id, createdAt])
  @@index([isRead])
}

model Position {
  id          String       @id @default(uuid())
  name        String       @unique @db.VarChar(50)
  information String?
  phone       String?
  open_date   String?
  open_time   String?
  close_time  String?
  latitude    Float
  longitude   Float
  image       String?
  find_match  Find_Match[]
  location    Location[]
  match       Match[]

  @@index([name, open_date, open_time])
}

model Experience {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  content     String?
  status      Int
  match_id    String
  reviewer_id String
  reviewee_id String
  match       Match    @relation(fields: [match_id], references: [id])
  reviewee    User     @relation("RevieweeExperience", fields: [reviewee_id], references: [user_id])
  reviewer    User     @relation("ReviewerExperience", fields: [reviewer_id], references: [user_id])

  @@index([match_id, reviewer_id, reviewee_id, status])
}

model Cancellation {
  id              String         @id @default(uuid())
  content         String?
  match_id        String
  reviewer_id     String
  reviewee_id     String
  quick_select_id String?
  createdAt       DateTime       @default(now())
  match           Match          @relation(fields: [match_id], references: [id])
  quick_select    Select_Cancel? @relation(fields: [quick_select_id], references: [id])
  reviewee        User           @relation("RevieweeCancellation", fields: [reviewee_id], references: [user_id])
  reviewer        User           @relation("ReviewerCancellation", fields: [reviewer_id], references: [user_id])

  @@index([match_id, reviewer_id, reviewee_id])
}

model Select_Cancel {
  id           String         @id @default(uuid())
  name         String         @unique @db.VarChar(50)
  cancellation Cancellation[]

  @@index([name])
}

model Notification {
  id          String              @id @default(uuid())
  sender_id   String
  receiver_id String
  type        Notification_Type
  status      Notification_Status @default(pending)
  position_id String?
  activity_id String?
  createdAt   DateTime            @default(now())
  receiver    User                @relation("ReceiverNotification", fields: [receiver_id], references: [user_id])
  sender      User                @relation("SenderNotification", fields: [sender_id], references: [user_id])

  @@index([receiver_id, status])
  @@index([sender_id])
}

enum Location_Proposal_Status {
  pending
  accepted
  rejected
}

enum Notification_Type {
  match_request
  match_accepted
}

enum Notification_Status {
  pending
  accepted
  rejected
}

enum Sex {
  male
  female
  lgbtq
}

enum Role {
  user
  admin
}

enum Blood_Group {
  A
  B
  AB
  O
}
